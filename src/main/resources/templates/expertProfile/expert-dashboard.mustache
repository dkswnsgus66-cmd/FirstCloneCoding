{{> layout/header}}

<style>
    /* ── 대시보드 탭 ── */
    .dash-tabs-bar {
        background: #fff;
        border-bottom: 2px solid #eaecf4;
        position: sticky;
        top: 64px;
        z-index: 90;
    }
    .dash-tabs-inner {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 28px;
        display: flex;
    }
    .dash-tab {
        padding: 13px 20px;
        font-size: 13px;
        font-weight: 600;
        color: #6b7280;
        border-bottom: 2px solid transparent;
        margin-bottom: -2px;
        white-space: nowrap;
        transition: color .15s, border-color .15s;
    }
    .dash-tab:hover { color: #1c1e26; border-color: #d1d5db; }

    /* ── 대시보드 본문 ── */
    .dash-section { padding: 16px 28px 0; }
    .dash-inner { max-width: 1200px; margin: 0 auto; }

    /* 4컬럼 그리드: 좌 | 중 | 우(메인) | 우(배너) */
    .dash-grid {
        display: grid;
        grid-template-columns: 200px 1fr 260px 185px;
        gap: 14px;
        align-items: stretch; /* 모든 컬럼 같은 높이 */
    }

    /* 컬럼 래퍼: flex로 카드 세로 배치 */
    .dash-col {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    /* ── 카드 공통 ── */
    .dash-card {
        background: #fff;
        border: 1.5px solid #eaecf4;
        border-radius: 12px;
        overflow: hidden;
        display: flex;
        flex-direction: column;
    }
    /* 마지막 카드가 남은 높이를 채움 */
    .dash-col .dash-card:last-child { flex: 1; }

    .dash-card-header {
        padding: 10px 14px;
        border-bottom: 1px solid #f0f2f9;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-shrink: 0;
    }
    .dash-card-title { font-size: 12px; font-weight: 700; color: #1c1e26; }
    .dash-card-more  { font-size: 11px; color: #2563eb; font-weight: 600; }
    .dash-card-more:hover { text-decoration: underline; }

    .dash-card-body {
        padding: 12px 14px;
        flex: 1;
        display: flex;
        flex-direction: column;
    }

    /* ── 전문가 프로필 ── */
    .expert-avatar {
        width: 52px; height: 52px;
        border-radius: 50%;
        background: #eff6ff; border: 2px solid #bfdbfe;
        display: flex; align-items: center; justify-content: center;
        font-size: 22px;
        margin: 0 auto 8px;
    }
    .expert-name { text-align: center; font-size: 13px; font-weight: 700; color: #1c1e26; margin-bottom: 3px; }
    .expert-role-badge {
        display: block; text-align: center;
        font-size: 10px; color: #2563eb;
        background: #eff6ff; border: 1px solid #bfdbfe;
        border-radius: 20px; padding: 2px 10px;
        width: fit-content; margin: 0 auto 10px; font-weight: 600;
    }
    .expert-stats { display: grid; grid-template-columns: 1fr 1fr; gap: 6px; }
    .expert-stat  { background: #f8f9fc; border-radius: 8px; padding: 7px 4px; text-align: center; }
    .expert-stat-val { display: block; font-size: 16px; font-weight: 900; color: #2563eb; margin-bottom: 1px; }
    .expert-stat-lbl { font-size: 9px; color: #9ca3af; font-weight: 500; }

    /* ── 빠른 링크 ── */
    .quick-links { display: flex; flex-direction: column; gap: 6px; }
    .quick-link {
        display: flex; align-items: center; gap: 8px;
        padding: 8px 10px; border-radius: 8px;
        font-size: 12px; font-weight: 600; color: #4b5563;
        background: #f8f9fc; border: 1.5px solid #eaecf4;
        transition: all .15s;
    }
    .quick-link:hover { background: #eff6ff; border-color: #bfdbfe; color: #2563eb; }
    .quick-link-icon { font-size: 13px; flex-shrink: 0; }

    /* ── 섹션 링크 카드 ── */
    .section-links { display: flex; flex-direction: column; gap: 7px; }
    .section-link-card {
        display: block; padding: 9px 12px;
        background: #f8f9fc; border: 1.5px solid #eaecf4;
        border-radius: 9px; transition: all .2s;
    }
    .section-link-card:hover {
        background: #eff6ff; border-color: #bfdbfe;
        box-shadow: 0 2px 10px rgba(37,99,235,.07);
        transform: translateX(2px);
    }
    .section-link-top {
        display: flex; align-items: center;
        justify-content: space-between; margin-bottom: 2px;
    }
    .section-link-title {
        font-size: 12px; font-weight: 700; color: #1c1e26;
        display: flex; align-items: center; gap: 5px;
    }
    .section-link-arrow { font-size: 16px; color: #c4c9d9; }
    .section-link-desc  { font-size: 10px; color: #9ca3af; line-height: 1.4; }

    /* ── 뱃지 ── */
    .badge-live {
        font-size: 9px; font-weight: 700; padding: 1px 6px;
        border-radius: 20px; background: #dcfce7; color: #16a34a; border: 1px solid #bbf7d0;
    }
    .badge-ws {
        font-size: 9px; font-weight: 700; padding: 1px 6px;
        border-radius: 20px; background: #fdf4ff; color: #9333ea; border: 1px solid #e9d5ff;
    }

    /* ── 알림 ── */
    .notification-empty { text-align: center; padding: 10px 0; font-size: 12px; color: #c4c9d9; }

    /* ── 채팅 프리뷰 ── */
    .chat-panel-preview {
        background: #f8f9fc; border-radius: 9px;
        padding: 10px 12px; margin-top: 8px; flex: 1;
    }
    .chat-preview-header {
        font-size: 10px; font-weight: 700; color: #6b7280;
        margin-bottom: 7px; display: flex; align-items: center; gap: 5px;
    }
    .chat-bubble {
        background: #fff; border: 1px solid #e8ecf8;
        border-radius: 7px; padding: 6px 10px; margin-bottom: 5px;
    }
    .chat-bubble-name { font-size: 9px; font-weight: 700; color: #2563eb; margin-bottom: 2px; }
    .chat-bubble-text { font-size: 11px; color: #4b5563; line-height: 1.4; }
    .chat-open-btn {
        display: block; text-align: center; margin-top: 8px;
        font-size: 11px; color: #2563eb; font-weight: 600;
    }

    /* ── 프로젝트 검색 ── */
    .projects-section {
        background: #fff; border-top: 1px solid #eaecf4;
        padding: 24px 28px 40px; margin-top: 16px;
    }
    .projects-inner { max-width: 1200px; margin: 0 auto; }
    .proj-head {
        display: flex; justify-content: space-between;
        align-items: center; margin-bottom: 14px;
    }
    .proj-title { font-size: 16px; font-weight: 900; color: #1c1e26; letter-spacing: -0.5px; }
    .proj-view-all { font-size: 12px; color: #2563eb; font-weight: 600; }
    .proj-view-all:hover { text-decoration: underline; }
    .proj-search-bar { display: flex; gap: 8px; margin-bottom: 12px; }
    .proj-search-input {
        flex: 1; padding: 10px 14px;
        background: #f8f9fc; border: 1.5px solid #e2e5ef;
        border-radius: 9px; font-size: 13px; font-family: inherit;
        color: #1c1e26; outline: none; transition: border-color .15s;
    }
    .proj-search-input:focus { border-color: #2563eb; background: #fff; }
    .proj-search-btn {
        padding: 10px 22px; background: #2563eb; color: #fff;
        border: none; border-radius: 9px; font-size: 13px;
        font-weight: 700; cursor: pointer; font-family: inherit;
    }
    .proj-search-btn:hover { background: #1d4ed8; }
    .proj-mini-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; }
    .proj-mini-card {
        display: block; background: #fff;
        border: 1.5px solid #eaecf4; border-radius: 12px;
        padding: 16px; transition: all .2s;
    }
    .proj-mini-card:hover {
        border-color: #bfdbfe;
        box-shadow: 0 4px 14px rgba(37,99,235,.07);
        transform: translateY(-2px);
    }
    .proj-mini-cat {
        font-size: 10px; font-weight: 700; color: #2563eb;
        background: #eff6ff; padding: 2px 7px;
        border-radius: 5px; display: inline-block; margin-bottom: 8px;
    }
    .proj-mini-title { font-size: 13px; font-weight: 700; color: #1c1e26; margin-bottom: 5px; line-height: 1.4; }
    .proj-mini-desc  { font-size: 11px; color: #9ca3af; line-height: 1.5; margin-bottom: 10px; }
    .proj-mini-bottom {
        display: flex; justify-content: space-between; align-items: center;
        border-top: 1px solid #f3f4f8; padding-top: 8px;
    }
    .proj-mini-budget { font-size: 12px; font-weight: 900; color: #1c1e26; }
    .proj-mini-dday  { font-size: 11px; font-weight: 600; color: #c4c9d9; }
    .proj-mini-dday.urgent { color: #ef4444; }
</style>

