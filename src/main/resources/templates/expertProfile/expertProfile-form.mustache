{{> layout/header}}

<style>
    .save-section { padding: 52px 28px 80px; }
    .save-inner { max-width: 760px; margin: 0 auto; }
    .save-header { margin-bottom: 32px; }
    .save-title { font-size: 24px; font-weight: 900; color: #1c1e26; letter-spacing: -0.5px; margin-bottom: 6px; }
    .save-desc { font-size: 14px; color: #9ca3af; }
    .notice-box { background: #eff6ff; border: 1px solid #bfdbfe; border-radius: 10px; padding: 14px 18px; font-size: 13px; color: #2563eb; font-weight: 500; margin-bottom: 28px; line-height: 1.7; }
    .save-form { display: flex; flex-direction: column; gap: 22px; }
    .form-group { display: flex; flex-direction: column; gap: 8px; }
    .form-label { font-size: 13px; font-weight: 700; color: #374151; }
    .form-label .required { color: #ef4444; margin-left: 2px; }
    .form-input { padding: 13px 16px; background: #fff; border: 1.5px solid #e2e5ef; border-radius: 10px; font-size: 14px; font-family: inherit; color: #1c1e26; outline: none; transition: border-color .15s; }
    .form-input::placeholder { color: #c4c9d9; }
    .form-input:focus { border-color: #2563eb; }
    .form-select { padding: 13px 16px; background: #fff; border: 1.5px solid #e2e5ef; border-radius: 10px; font-size: 14px; font-family: inherit; color: #1c1e26; outline: none; cursor: pointer; }
    .form-select:focus { border-color: #2563eb; }
    .form-textarea { padding: 13px 16px; background: #fff; border: 1.5px solid #e2e5ef; border-radius: 10px; font-size: 14px; font-family: inherit; color: #1c1e26; outline: none; resize: vertical; min-height: 180px; line-height: 1.7; transition: border-color .15s; }
    .form-textarea::placeholder { color: #c4c9d9; }
    .form-textarea:focus { border-color: #2563eb; }
    .form-hint { font-size: 12px; color: #9ca3af; }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    .form-btns { display: flex; justify-content: flex-end; gap: 10px; margin-top: 8px; }
    .btn { display: inline-block; padding: 10px 22px; border-radius: 8px; font-size: 14px; font-weight: 600; cursor: pointer; border: none; font-family: inherit; transition: all .15s; text-decoration: none; }
    .btn-primary { background: #2563eb; color: #fff; }
    .btn-primary:hover { background: #1d4ed8; }
    .btn-outline { background: #fff; border: 1.5px solid #e2e5ef; color: #4b5563; }
    .btn-lg { padding: 14px 32px; font-size: 15px; border-radius: 10px; }
</style>

<section class="save-section">
    <div class="save-inner">

        <div class="save-header">
            <h1 class="save-title">⭐ 인증 전문가 신청</h1>
            <p class="save-desc">전문가 프로필을 작성하고 인증 전문가에 도전하세요.</p>
        </div>

        <div class="notice-box">
            📋 인증 심사 안내<br>
            제출된 프로필은 관리자 검토 후 승인됩니다. 승인까지 최대 3 영업일이 소요될 수 있습니다.
        </div>

        <form class="save-form" action="/expert-profile/save" method="POST">

            <div class="form-group">
                <label class="form-label">직종 / 전문 분야 <span class="required">*</span></label>
                <select name="career" class="form-select">
                    <option value="">선택하세요</option>
                    <option value="풀스택">풀스택 개발자</option>
                    <option value="백엔드">백엔드 개발자</option>
                    <option value="프론트엔드">프론트엔드 개발자</option>
                    <option value="앱개발">앱 개발자</option>
                    <option value="UI/UX">UI/UX 디자이너</option>
                    <option value="데이터">데이터 엔지니어</option>
                    <option value="영상편집">영상 편집</option>
                    <option value="기타">기타</option>
                </select>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">경력 연수 <span class="required">*</span></label>
                    <input type="number" name="experienceYears" class="form-input" placeholder="예: 3" min="0" max="50" />
                </div>
                <div class="form-group">
                    <label class="form-label">주요 기술 스택</label>
                    <input type="text" name="skills" class="form-input" placeholder="예: Java, Spring Boot, React" />
                </div>
            </div>

            <div class="form-group">
                <label class="form-label">자기소개 <span class="required">*</span></label>
                <textarea name="introduce" class="form-textarea" placeholder="본인의 경력, 강점, 대표 프로젝트 경험 등을 소개해주세요."></textarea>
            </div>

            <div class="form-group">
                <label class="form-label">포트폴리오 URL</label>
                <input type="url" name="portfolioUrl" class="form-input" placeholder="https://github.com/..." />
                <span class="form-hint">GitHub, Notion, 개인 블로그 등 자유롭게 입력하세요.</span>
            </div>

            <div class="form-btns">
                <a href="/mypage" class="btn btn-outline">취소</a>
                <button type="submit" class="btn btn-primary btn-lg">신청서 제출</button>
            </div>

        </form>
    </div>
</section>

{{> layout/footer}}
