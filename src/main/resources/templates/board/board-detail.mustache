{{> layout/header}}

<style>
    /* ── BOARD DETAIL ── */
    .detail-section { padding: 52px 28px 80px; }
    .detail-inner { max-width: 860px; margin: 0 auto; }

    /* 상단 네비 */
    .detail-nav { display: flex; align-items: center; gap: 8px; font-size: 13px; color: #9ca3af; margin-bottom: 32px; }
    .detail-nav a { color: #9ca3af; }
    .detail-nav a:hover { color: #2563eb; }
    .detail-nav span { color: #d1d5db; }

    /* 게시글 헤더 */
    .detail-header { padding-bottom: 24px; border-bottom: 1.5px solid #eaecf4; margin-bottom: 28px; }
    .detail-category { font-size: 11px; font-weight: 700; color: #2563eb; background: #eff6ff; padding: 4px 10px; border-radius: 6px; display: inline-block; margin-bottom: 14px; }
    .detail-title { font-size: 26px; font-weight: 900; color: #1c1e26; letter-spacing: -0.5px; line-height: 1.35; margin-bottom: 16px; }
    .detail-meta { display: flex; align-items: center; gap: 20px; font-size: 13px; color: #9ca3af; font-weight: 500; }
    .detail-meta .author { color: #374151; font-weight: 700; }
    .detail-meta-dot { width: 3px; height: 3px; border-radius: 50%; background: #d1d5db; }

    /* 게시글 액션 버튼 */
    .detail-actions { display: flex; justify-content: flex-end; gap: 8px; margin-bottom: 28px; }

    /* 본문 */
    .detail-content { font-size: 15px; color: #374151; line-height: 1.9; min-height: 200px; margin-bottom: 48px; white-space: pre-wrap; }

    /* 목록으로 */
    .detail-footer { display: flex; justify-content: space-between; align-items: center; padding-top: 28px; border-top: 1px solid #eaecf4; margin-bottom: 56px; }

    /* 댓글 섹션 */
    .comment-section { border-top: 2px solid #1c1e26; padding-top: 32px; }
    .comment-title { font-size: 16px; font-weight: 900; color: #1c1e26; margin-bottom: 24px; display: flex; align-items: center; gap: 8px; }
    .comment-count { font-size: 14px; font-weight: 700; color: #2563eb; background: #eff6ff; padding: 2px 10px; border-radius: 20px; }

    /* 댓글 작성 폼 */
    .comment-form { background: #f8f9fc; border-radius: 12px; padding: 18px; margin-bottom: 28px; display: flex; flex-direction: column; gap: 12px; }
    .comment-textarea { width: 100%; padding: 12px 14px; background: #fff; border: 1.5px solid #e2e5ef; border-radius: 9px; font-size: 14px; font-family: inherit; color: #1c1e26; outline: none; resize: none; height: 90px; line-height: 1.7; transition: border-color .15s; }
    .comment-textarea::placeholder { color: #c4c9d9; }
    .comment-textarea:focus { border-color: #2563eb; }
    .comment-form-footer { display: flex; justify-content: flex-end; }

    /* 댓글 목록 */
    .comment-list { display: flex; flex-direction: column; gap: 0; }
    .comment-item { padding: 20px 0; border-bottom: 1px solid #f3f4f8; }
    .comment-item:last-child { border-bottom: none; }
    .comment-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 10px; }
    .comment-author-wrap { display: flex; align-items: center; gap: 10px; }
    .comment-avatar { width: 34px; height: 34px; border-radius: 10px; background: #eff6ff; border: 1px solid #bfdbfe; display: flex; align-items: center; justify-content: center; font-size: 15px; flex-shrink: 0; }
    .comment-author { font-size: 13px; font-weight: 700; color: #1c1e26; }
    .comment-date { font-size: 11px; color: #c4c9d9; margin-top: 2px; }
    .comment-actions { display: flex; gap: 8px; }
    .comment-btn { font-size: 12px; color: #9ca3af; font-weight: 600; background: none; border: none; cursor: pointer; font-family: inherit; padding: 0; }
    .comment-btn:hover { color: #2563eb; }
    .comment-btn.delete:hover { color: #ef4444; }
    .comment-content { font-size: 14px; color: #374151; line-height: 1.75; padding-left: 44px; }

    /* 댓글 없을 때 */
    .comment-empty { text-align: center; padding: 40px 0; font-size: 14px; color: #c4c9d9; }
</style>

<section class="detail-section">
    <div class="detail-inner">

        <!-- 브레드크럼 -->
        <div class="detail-nav">
            <a href="/boards?boardType={{board.boardType}}">게시판</a>
            <span>›</span>
            <span>{{board.title}}</span>
        </div>

        <!-- 게시글 헤더 -->
        <div class="detail-header">
            <span class="detail-category">{{board.boardType}}</span>
            <h1 class="detail-title">{{board.title}}</h1>
            <div class="detail-meta">
                <span class="author">{{board.memberName}}</span>
                <div class="detail-meta-dot"></div>
                <span>{{board.createdAt}}</span>
                <div class="detail-meta-dot"></div>
                <span>조회 {{board.viewCount}}</span>
            </div>
        </div>

        <!-- 수정/삭제 버튼 (작성자 본인만) -->
        {{#isOwner}}
        <div class="detail-actions">
            <a href="/boards/{{board.id}}/edit" class="btn btn-outline btn-sm">수정</a>
            <form action="/boards/{{board.id}}/delete" method="POST" style="display:inline;">
                <button type="submit" class="btn btn-sm" style="background:#fff3f3; color:#ef4444; border:1.5px solid #fecaca;">삭제</button>
            </form>
        </div>
        {{/isOwner}}

        <!-- 본문 -->
        <div class="detail-content">{{board.content}}</div>

        <!-- 하단 -->
        <div class="detail-footer">
            <a href="/boards?boardType={{board.boardType}}" class="btn btn-outline">← 목록으로</a>
        </div>

        <!-- =====================================================
             댓글 섹션
             - comments : 댓글 리스트
             - comment.id / memberName / content / createdAt
             - isCommentOwner : 댓글 작성자 본인 여부
        ====================================================== -->
        <div class="comment-section">

            <div class="comment-title">
                댓글
            </div>

            <!-- 댓글 작성 폼 -->
<!--            <form class="comment-form" action="/boards/{{!board.id}}/comments/save" method="POST">-->
<!--                <textarea-->
<!--                    class="comment-textarea"-->
<!--                    name="content"-->
<!--                    placeholder="댓글을 입력하세요..."-->
<!--                ></textarea>-->
<!--                <div class="comment-form-footer">-->
<!--                    <button type="submit" class="btn btn-primary btn-sm">등록</button>-->
<!--                </div>-->
<!--            </form>-->

            <!-- 댓글 목록 나중에 작업 -->
            <div class="comment-list">
                {{#comments}}
                <div class="comment-item">
                    <div class="comment-header">
                        <div class="comment-author-wrap">
                            <div class="comment-avatar">👤</div>
                            <div>
                                <div class="comment-author">{{memberName}}</div>
                                <div class="comment-date">{{createdAt}}</div>
                            </div>
                        </div>
                        {{#isOwner}}
                        <div class="comment-actions">
                            <button class="comment-btn">수정</button>
                            <form action="/boards/{{board.id}}/comments/{{id}}/delete" method="POST" style="display:inline;">
                                <button type="submit" class="comment-btn delete">삭제</button>
                            </form>
                        </div>
                        {{/isOwner}}
                    </div>
                    <div class="comment-content">{{!comment}}</div>
                </div>
                {{/comments}}

                {{^comments}}
                <div class="comment-empty">아직 댓글이 없습니다. 첫 댓글을 남겨보세요!</div>
                {{/comments}}

            </div>
        </div>

    </div>
</section>

{{> layout/footer}}
