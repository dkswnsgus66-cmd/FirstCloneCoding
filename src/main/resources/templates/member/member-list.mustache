{{> layout/header}}

<style>
    .page-header { background: #fff; border-bottom: 1px solid #eaecf4; padding: 40px 28px 28px; }
    .page-header-inner { max-width: 1140px; margin: 0 auto; }
    .page-title { font-size: 26px; font-weight: 900; color: #1c1e26; letter-spacing: -0.5px; margin-bottom: 6px; }
    .page-desc { font-size: 14px; color: #9ca3af; }
    .list-section { padding: 36px 28px 80px; }
    .list-inner { max-width: 1140px; margin: 0 auto; }
    .search-bar { display: flex; gap: 10px; margin-bottom: 20px; }
    .search-input { flex: 1; padding: 12px 16px; background: #fff; border: 1.5px solid #e2e5ef; border-radius: 9px; font-size: 14px; font-family: inherit; color: #1c1e26; outline: none; max-width: 400px; }
    .search-input:focus { border-color: #2563eb; outline: none; }
    .search-btn { padding: 12px 24px; background: #2563eb; color: #fff; border: none; border-radius: 9px; font-size: 14px; font-weight: 700; cursor: pointer; font-family: inherit; }
    .list-count { font-size: 14px; color: #9ca3af; font-weight: 500; margin-bottom: 16px; }
    .list-count strong { color: #1c1e26; font-weight: 700; }
    .member-table { width: 100%; background: #fff; border-radius: 14px; border: 1.5px solid #eaecf4; overflow: hidden; margin-bottom: 28px; }
    .member-table-head { display: grid; grid-template-columns: 60px 1fr 160px 120px 80px 100px; gap: 12px; padding: 13px 24px; background: #f8f9fc; border-bottom: 1px solid #eaecf4; font-size: 11px; font-weight: 700; color: #9ca3af; letter-spacing: .5px; }
    .member-table-row { display: grid; grid-template-columns: 60px 1fr 160px 120px 80px 100px; gap: 12px; padding: 16px 24px; border-bottom: 1px solid #f3f4f8; align-items: center; font-size: 13px; }
    .member-table-row:last-child { border-bottom: none; }
    .member-table-row:hover { background: #f8f9ff; }
    .cell-id { color: #c4c9d9; font-weight: 500; }
    .cell-name { font-weight: 700; color: #1c1e26; margin-bottom: 2px; }
    .cell-phone { font-size: 12px; color: #9ca3af; }
    .cell-email { font-size: 12px; color: #9ca3af; }
    .cell-date { font-size: 12px; color: #c4c9d9; }
    .role-admin { font-size: 11px; background: #fef3c7; color: #b45309; border: 1px solid #fde68a; padding: 3px 10px; border-radius: 20px; font-weight: 700; display: inline-block; }
    .role-expert { font-size: 11px; background: #eff6ff; color: #2563eb; border: 1px solid #bfdbfe; padding: 3px 10px; border-radius: 20px; font-weight: 700; display: inline-block; }
    .role-client { font-size: 11px; background: #f0fdf4; color: #059669; border: 1px solid #a7f3d0; padding: 3px 10px; border-radius: 20px; font-weight: 700; display: inline-block; }
    .status-active { font-size: 11px; background: #ecfdf5; color: #059669; border: 1px solid #a7f3d0; padding: 3px 10px; border-radius: 20px; font-weight: 700; display: inline-block; }
    .status-suspended { font-size: 11px; background: #fff3f3; color: #ef4444; border: 1px solid #fecaca; padding: 3px 10px; border-radius: 20px; font-weight: 700; display: inline-block; }
    .empty-state { text-align: center; padding: 60px 0; font-size: 15px; color: #c4c9d9; }
    .paging { display: flex; justify-content: center; gap: 6px; }
    .page-btn { padding: 9px 15px; border-radius: 8px; border: 1.5px solid #e2e5ef; font-size: 13px; font-weight: 600; color: #6b7280; background: #fff; text-decoration: none; transition: all .15s; }
    .page-btn:hover { border-color: #2563eb; color: #2563eb; }
    .page-btn.active { background: #2563eb; border-color: #2563eb; color: #fff; }
</style>

<div class="page-header">
    <div class="page-header-inner">
        <h1 class="page-title">회원 목록</h1>
        <p class="page-desc">가입된 전체 회원을 조회합니다.</p>
    </div>
</div>

<section class="list-section">
    <div class="list-inner">

        <div class="search-bar">
            <input type="text" class="search-input" placeholder="이름 또는 이메일로 검색..." value="{{keyword}}" />
            <button class="search-btn">검색</button>
        </div>

        <div class="list-count">총 <strong>{{memberCount}}</strong>명의 회원</div>

        <div class="member-table">
            <div class="member-table-head">
                <span>No</span>
                <span>이름 / 이메일</span>
                <span>전화번호</span>
                <span>가입일</span>
                <span>권한</span>
                <span>상태</span>
            </div>

            {{#members}}
                <div class="member-table-row">
                    <span class="cell-id">{{id}}</span>
                    <div>
                        <div class="cell-name">{{name}}</div>
                        <div class="cell-email">{{email}}</div>
                    </div>
                    <span class="cell-phone">{{phone}}</span>
                    <span class="cell-date">{{createdAt}}</span>
                    <span>
                    {{#isAdmin}}<span class="role-admin">관리자</span>{{/isAdmin}}
                        {{#isExpert}}<span class="role-expert">전문가</span>{{/isExpert}}
                        {{#isClient}}<span class="role-client">의뢰인</span>{{/isClient}}
                </span>
                    <span>
                    {{#isActive}}<span class="status-active">활성</span>{{/isActive}}
                        {{^isActive}}<span class="status-suspended">정지</span>{{/isActive}}
                </span>
                </div>
            {{/members}}

            {{^members}}
                <div class="empty-state">검색 결과가 없습니다.</div>
            {{/members}}

        </div>

        <div class="paging">
            {{#paging}}
                {{#hasPrev}}<a href="/admin/members?page={{prevPage}}&keyword={{keyword}}" class="page-btn">이전</a>{{/hasPrev}}
                {{#pageList}}<a href="/admin/members?page={{num}}&keyword={{keyword}}" class="page-btn {{#isCurrent}}active{{/isCurrent}}">{{num}}</a>{{/pageList}}
                {{#hasNext}}<a href="/admin/members?page={{nextPage}}&keyword={{keyword}}" class="page-btn">다음</a>{{/hasNext}}
            {{/paging}}
        </div>

    </div>
</section>

{{> layout/footer}}