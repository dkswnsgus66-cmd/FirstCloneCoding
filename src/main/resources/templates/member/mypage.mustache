{{> layout/header}}

<style>
    .mypage-section { padding: 52px 28px 80px; }
    .mypage-inner { max-width: 1000px; margin: 0 auto; display: flex; flex-direction: column; gap: 32px; }
    /* 프로필 카드 */
    .profile-card { background: #fff; border: 1.5px solid #eaecf4; border-radius: 18px; padding: 24px 32px; display: flex; align-items: center; gap: 32px; text-align: left; position: static; }
.profile-avatar { width: 72px; height: 72px; border-radius: 50%; background: #eff6ff; border: 2px solid #bfdbfe; display: flex; align-items: center; justify-content: center; font-size: 32px; flex-shrink: 0; margin: 0; }
    .profile-name { font-size: 18px; font-weight: 900; color: #1c1e26; margin-bottom: 4px; }
    .profile-email { font-size: 13px; color: #9ca3af; margin-bottom: 14px; }
    .profile-badge { font-size: 11px; background: #fffbeb; color: #b45309; border: 1px solid #fde68a; padding: 4px 12px; border-radius: 20px; font-weight: 700; display: inline-block; margin-bottom: 20px; }
    ..profile-stats { display: flex; gap: 20px; margin-bottom: 0; }
.profile-start { background: #f8f9fc; border-radius: 10px; padding: 12px; min-width: 80px; }
    .profile-stat-val { font-size: 20px; font-weight: 900; color: #2563eb; }
    .profile-stat-lbl { font-size: 11px; color: #9ca3af; margin-top: 2px; }
    .profile-btns { display: flex; flex-direction: row; gap: 8px; margin-left: auto; }
    .profile-btn { padding: 11px; border-radius: 9px; font-size: 13px; font-weight: 700; cursor: pointer; border: none; font-family: inherit; text-decoration: none; display: block; text-align: center; }
    .profile-btn-primary { background: #2563eb; color: #fff; }
    .profile-btn-outline { background: #fff; border: 1.5px solid #e2e5ef; color: #4b5563; }
    .profile-btn-danger { background: #fff3f3; color: #ef4444; border: 1.5px solid #fecaca; }
    /* 탭 콘텐츠 */
    .mypage-tabs { display: flex; gap: 0; border-bottom: 2px solid #eaecf4; margin-bottom: 24px; }
    .mypage-tab { padding: 11px 20px; font-size: 14px; font-weight: 700; color: #9ca3af; border-bottom: 3px solid transparent; margin-bottom: -2px; text-decoration: none; transition: all .15s; }
    .mypage-tab:hover { color: #1c1e26; }
    .mypage-tab.active { color: #2563eb; border-bottom-color: #2563eb; }
    /* 프로젝트 목록 */
    .my-list { display: flex; flex-direction: column; gap: 12px; }
    .my-item { background: #fff; border: 1.5px solid #eaecf4; border-radius: 12px; padding: 18px 20px; display: flex; justify-content: space-between; align-items: center; text-decoration: none; color: inherit; transition: border-color .15s; }
    .my-item:hover { border-color: #bfdbfe; }
    .my-item-body { flex: 1; }
    .my-item-cat { font-size: 11px; font-weight: 700; color: #2563eb; background: #eff6ff; padding: 3px 9px; border-radius: 5px; display: inline-block; margin-bottom: 6px; }
    .my-item-title { font-size: 15px; font-weight: 700; color: #1c1e26; margin-bottom: 4px; }
    .my-item-meta { font-size: 12px; color: #9ca3af; }
    .my-item-right { text-align: right; flex-shrink: 0; margin-left: 16px; }
    .my-item-price { font-size: 15px; font-weight: 900; color: #1c1e26; }
    .my-item-status { font-size: 11px; margin-top: 6px; padding: 3px 10px; border-radius: 20px; font-weight: 700; display: inline-block; }
    .status-open { background: #ecfdf5; color: #059669; border: 1px solid #a7f3d0; }
    .status-closed { background: #f3f4f8; color: #9ca3af; }
    .status-wait { background: #f3f4f8; color: #9ca3af; }
    .status-done { background: #ecfdf5; color: #059669; border: 1px solid #a7f3d0; }
    .empty-state { text-align: center; padding: 60px 0; font-size: 15px; color: #c4c9d9; }
    /* 정보 수정 폼 */
    .edit-form { background: #fff; border: 1.5px solid #eaecf4; border-radius: 14px; padding: 28px; display: flex; flex-direction: column; gap: 18px; }
    .form-group { display: flex; flex-direction: column; gap: 7px; }
    .form-label { font-size: 13px; font-weight: 700; color: #374151; }
    .form-input { padding: 12px 16px; background: #f8f9fc; border: 1.5px solid #e2e5ef; border-radius: 9px; font-size: 14px; font-family: inherit; color: #1c1e26; outline: none; transition: border-color .15s; }
    .form-input:focus { border-color: #2563eb; background: #fff; }
    .form-btns { display: flex; justify-content: flex-end; gap: 10px; }
    .btn { display: inline-block; padding: 10px 22px; border-radius: 8px; font-size: 14px; font-weight: 600; cursor: pointer; border: none; font-family: inherit; transition: all .15s; }
    .btn-primary { background: #2563eb; color: #fff; }
    .btn-outline { background: #fff; border: 1.5px solid #e2e5ef; color: #4b5563; }
</style>

<section class="mypage-section">
    <div class="mypage-inner">

        <!-- 프로필 카드 -->
        <div class="profile-card">
            <div class="profile-avatar">👤</div>

            <div class="profile-info">
                <div class="profile-name">{{member.name}}</div>
                <div class="profile-email">{{member.email}}</div>
                {{#member.isCertified}}
                    <div class="profile-badge">⭐ 인증 전문가</div>{{/member.isCertified}}
                <div class="profile-stats">
                    {{^member.isExpert}}
                        <div class="profile-stat">
                            <div class="profile-stat-val">{{projectCount}}</div>
                            <div class="profile-stat-lbl">프로젝트</div>
                        </div>
                    {{/member.isExpert}}
                    {{#member.isExpert}}
                        <div class="profile-stat">
                            <div class="profile-stat-val">{{bidCount}}</div>
                            <div class="profile-stat-lbl">제안서</div>
                        </div>
                    {{/member.isExpert}}
                </div>
            </div>

            <!-- 버튼 영역 -->
            <div class="profile-btns">
                {{#member.isExpert}}
                    <a href="/portfolios/save" class="profile-btn profile-btn-outline">📁 포트폴리오</a>
                {{/member.isExpert}}
                {{^member.isCertified}}
                    <a href="/expert-profile/form" class="profile-btn profile-btn-primary">⭐ 인증 전문가 신청</a>
                {{/member.isCertified}}
                <a href="/logout" class="profile-btn profile-btn-danger">로그아웃</a>
            </div>
        </div>

        <!-- 탭 콘텐츠 -->
        <div>
            <div class="mypage-tabs">
                {{^member.isExpert}}
                    <a href="/mypage?tab=projects" class="mypage-tab {{#isProjects}}active{{/isProjects}}">내 프로젝트</a>
                {{/member.isExpert}}

                {{#member.isExpert}}
                    <a href="/mypage?tab=bids" class="mypage-tab {{#isBids}}active{{/isBids}}">내 제안서</a>
                    <a href="/mypage?tab=portfolios" class="mypage-tab {{#isPortfolio}}active{{/isPortfolio}}">내
                        포트폴리오</a>
                {{/member.isExpert}}
                <a href="/mypage?tab=boards" class="mypage-tab {{#isBoards}}active{{/isBoards}}">내 게시글</a>
                <a href="/mypage?tab=reviews" class="mypage-tab {{#isReview}}active{{/isReview}}">리뷰</a>
                <a href="/mypage?tab=edit" class="mypage-tab {{#isEdit}}active{{/isEdit}}">정보 수정</a>
            </div>

            {{! 내 프로젝트 }}
            {{#isProjects}}
                <div class="my-list">
                    {{#projects}}
                        <div class="my-item">
                            <div class="my-item-body">
                                <span class="my-item-cat">{{categoryName}}</span>
                                {{#isOpen}}
                                    <a href="/bid/list?projectId={{id}}" style="text-decoration:none; color:inherit;">
                                    <div class="my-item-title">{{title}}</div>
                                    </a>
                                {{/isOpen}}
                                {{^isOpen}}
                                    <a href="/projects/{{id}}/detail" style="text-decoration:none; color:inherit;">
                                        <div class="my-item-title">{{title}}</div>
                                    </a>
                                {{/isOpen}}
                                <div class="my-item-meta">등록일 {{createdAt}} · 입찰 {{bidCount}}개</div>
                            </div>
                            <div class="my-item-right">
                                <div class="my-item-price">{{budgetMin}}~{{budgetMax}}만원</div>
                                <span class="my-item-status {{#isOpen}}status-open{{/isOpen}}{{^isOpen}}status-closed{{/isOpen}}">
                                {{#isOpen}}모집중{{/isOpen}}{{^isOpen}}마감{{/isOpen}}
                             </span>
                                {{! 마감된 프로젝트에만 리뷰 버튼 }}
                                {{^isOpen}}
                                    <a href="/reviews/save?targetId={{selectedExpertId}}" class="btn btn-primary"
                                    style="font-size:12px; padding:6px 12px; margin-top:8px; display:block;">리뷰 작성</a>
                                {{/isOpen}}
                            </div>
                        </div>
                    {{/projects}}
                    {{^projects}}
                        <div class="empty-state">등록한 프로젝트가 없습니다.</div>{{/projects}}
                </div>
            {{/isProjects}}

            {{! 내 제안서 }}
            {{#isBids}}
                <div class="my-list">
                    {{#bids}}
                        <div class="my-item">
                            <a href="/projects/{{projectId}}" class="my-item-body"
                               style="text-decoration:none; color:inherit;">
                                <div class="my-item-title">{{projectTitle}}</div>
                                <div class="my-item-meta">제안일 {{createdAt}}</div>
                            </a>
                            <div class="my-item-right">
                                <div class="my-item-price">{{proposedPrice}}만원</div>
                                <span class="my-item-status {{#isSelected}}status-done{{/isSelected}}{{^isSelected}}status-wait{{/isSelected}}">
                            {{#isSelected}}낙찰{{/isSelected}}{{^isSelected}}대기중{{/isSelected}}
                        </span>
                                {{#isSelected}}
                                    <a href="/reviews/save?targetId={{memberId}}" class="btn btn-primary"
                                    style="font-size:12px; padding:6px 12px; margin-top:8px; display:block;">리뷰 작성</a>
                                {{/isSelected}}
                            </div>
                        </div>
                    {{/bids}}
                    {{^bids}}
                        <div class="empty-state">제출한 제안서가 없습니다.</div>{{/bids}}
                </div>
            {{/isBids}}

            {{! 내 포트폴리오 }}
            {{#isPortfolio}}
                <div class="my-list">
                    {{#portfolios}}
                        <a href="/portfolios/{{id}}" class="my-item">
                            <div class="my-item-body">
                                <div class="my-item-title">{{title}}</div>
                                <div class="my-item-meta">{{description}}</div>
                                <div class="my-item-meta">{{createdAt}}</div>
                            </div>
                        </a>
                    {{/portfolios}}
                    {{^portfolios}}
                        <div class="empty-state">등록한 포트폴리오가 없습니다.</div>{{/portfolios}}
                </div>
            {{/isPortfolio}}

            {{! 내 게시글 }}
            {{#isBoards}}
                <div class="my-list">
                    {{#boards}}
                        <a href="/boards/{{id}}" class="my-item">
                            <div class="my-item-body">
                                <span class="my-item-cat">{{boardType}}</span>
                                <div class="my-item-title">{{title}}</div>
                                <div class="my-item-meta">{{createdAt}} · 조회 {{viewCount}}</div>
                            </div>
                        </a>
                    {{/boards}}
                    {{^boards}}
                        <div class="empty-state">작성한 게시글이 없습니다.</div>{{/boards}}
                </div>
            {{/isBoards}}

            {{! 내 리뷰 }}
            {{#isReviews}}
                <div class="my-list">
                    {{#reviews}}
                        <a href="/reviews/{{id}}" class="my-item">
                            <div class="my-item-body">
                                <span class="my-item-cat">리뷰</span>
                                <div class="my-item-title">{{member.name}} 님이 받은 리뷰</div>
                                <div class="my-item-meta">{{content}}</div>
                                <div class="my-item-meta">{{createdAt}}</div>
                            </div>
                            <div class="my-item-right">
                                <span class="my-item-status status-done">★ 0</span>
                            </div>
                        </a>
                    {{/reviews}}
                    {{^reviews}}
                        <div class="empty-state">작성한 리뷰가 없습니다.</div>{{/reviews}}
                </div>
            {{/isReviews}}

            {{! 정보 수정 }}
            {{#isEdit}}
                <form class="edit-form" action="/mypage/update" method="POST">
                    <div class="form-group">
                        <label class="form-label">이름</label>
                        <input type="text" name="name" class="form-input" value="{{member.name}}"/>
                    </div>
                    <div class="form-group">
                        <label class="form-label">이메일</label>
                        <input type="email" class="form-input" value="{{member.email}}" disabled/>
                    </div>
                    <div class="form-group">
                        <label class="form-label">새 비밀번호</label>
                        <input type="password" name="newPassword" class="form-input" placeholder="변경할 경우만 입력"/>
                    </div>
                    <div class="form-group">
                        <label class="form-label">새 비밀번호 확인</label>
                        <input type="password" name="newPasswordConfirm" class="form-input" placeholder="변경할 경우만 입력"/>
                    </div>
                    <div class="form-btns">
                        <button type="submit" class="btn btn-primary">수정완료</button>
                    </div>
                </form>
            {{/isEdit}}
        </div>

    </div>
</section>

{{> layout/footer}}